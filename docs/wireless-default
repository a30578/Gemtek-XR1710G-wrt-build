# WiFi 默认配置
# 此文件在编译时由 workflow 动态替换 WiFi 密码

config wifi-device 'radio0'
    option type 'mac80211'
    option channel '1'
    option hwmode '11g'
    option htmode 'HE20'
    option disabled '0'

config wifi-iface 'default_radio0'
    option device 'radio0'
    option network 'lan'
    option mode 'ap'
    option encryption 'sae-mixed'
    option key '__WIFI_PASSWORD__'
    option ssid 'OpenWrt-2.4G'
    option FT_over_ds '1'
    option FT_primary_key '0'

config wifi-device 'radio1'
    option type 'mac80211'
    option channel '36'
    option hwmode '11a'
    option htmode 'HE80'
    option disabled '0'
    option num_sec_antennas '4'
    option txchain '15'
    option rxchain '15'

config wifi-iface 'default_radio1'
    option device 'radio1'
    option network 'lan'
    option mode 'ap'
    option encryption 'sae-mixed'
    option key '__WIFI_PASSWORD__'
    option ssid 'OpenWrt-5G'
    option FT_over_ds '1'
    option FT_primary_key '0'

config wifi-device 'radio2'
    option type 'mac80211'
    option channel '7'
    option hwmode '11a'
    option htmode 'HE160'
    option disabled '0'
    option num_sec_antennas '4'
    option txchain '15'
    option rxchain '15'
    option country 'CN'

config wifi-iface 'default_radio2'
    option device 'radio2'
    option network 'lan'
    option mode 'ap'
    option encryption 'sae-mixed'
    option key '__WIFI_PASSWORD__'
    option ssid 'OpenWrt-6G'
    option FT_over_ds '1'
    option FT_primary_key '0'